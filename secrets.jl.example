# Copy this file to `secrets.jl` and fill in your key.
# `secrets.jl` is git-ignored, so your key never gets committed.
#
# main.jl reads the key from the ANTHROPIC_API_KEY environment variable, so this
# file simply sets it. Alternatively, skip the file entirely and run:
#   export ANTHROPIC_API_KEY="sk-ant-..."

ENV["ANTHROPIC_API_KEY"] = "sk-ant-your-key-here"
